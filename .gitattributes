# ========================
# Code-Sprachen zuweisen
# ========================
*.py         linguist-language=Python
*.js         linguist-language=JavaScript
*.ts         linguist-language=TypeScript
*.jsx        linguist-language=JavaScript
*.tsx        linguist-language=TypeScript
*.java       linguist-language=Java
*.kt         linguist-language=Kotlin
*.c          linguist-language=C
*.h          linguist-language=C
*.cpp        linguist-language=C++
*.hpp        linguist-language=C++
*.cs         linguist-language=C#
*.go         linguist-language=Go
*.php        linguist-language=PHP
*.rb         linguist-language=Ruby
*.rs         linguist-language=Rust
*.swift      linguist-language=Swift
*.sh         linguist-language=Shell
*.bat        linguist-language=Batchfile
*.ps1        linguist-language=PowerShell
*.pl         linguist-language=Perl
*.r          linguist-language=R
*.scala      linguist-language=Scala
*.dart       linguist-language=Dart
*.lua        linguist-language=Lua

# ========================
# Markup / Datenformate
# ========================
*.html       linguist-language=HTML
*.css        linguist-language=CSS
*.scss       linguist-language=SCSS
*.yml        linguist-language=YAML
*.yaml       linguist-language=YAML
*.json       linguist-language=JSON
*.xml        linguist-language=XML
*.toml       linguist-language=TOML
*.ini        linguist-language=INI
*.cfg        linguist-language=INI
*.md         linguist-language=Markdown

# ========================
# Dokumentation
# ========================
README*       linguist-documentation
LICENSE*      linguist-documentation
docs/**       linguist-documentation

# ========================
# Build-/generierte Dateien ignorieren
# ========================
*.min.js     linguist-vendored
*.min.css    linguist-vendored
dist/**      linguist-vendored
build/**     linguist-vendored
node_modules/* linguist-vendored
vendor/**    linguist-vendored